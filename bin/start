#!/bin/zsh
# -----------------------------------------------------------------------------
# Constants
# -----------------------------------------------------------------------------
ABSPATH=$(readlink -f $0)
ABSDIR=$(dirname $ABSPATH)
# -----------------------------------------------------------------------------
# Imports
# -----------------------------------------------------------------------------
source "$ABSDIR/../config.conf"
# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
echo "Start $SERVICE_NAME..."

# Export global node paths if any
export PATH="/usr/bin:$PATH"

# Run npm script in background
cd "$ABSDIR/.." && npm run $NPM_SCRIPT -- --host $HOST --port $PORT >> /var/tmp/chatbot-web.log 2>&1 &
# -----------------------------------------------------------------------------
